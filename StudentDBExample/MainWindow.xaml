<Window x:Class="StudentDBExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentDBExample"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <StackPanel>
        <TextBlock x:Name="dataModel"
            Text="Student Manger Demo App"
            />
        <DataGrid x:Name="studentDg"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Height="300"
            />
        <!--Lets add a form-->
        <TextBox x:Name="StudentName" Text="NameHere" Margin="0.4" />
        <TextBox x:Name="StudentAge" Text="AgeHere" Margin="0.4" />
        <TextBox x:Name="StudentYearGroup" Text="YearGroupHere" Margin="0.4" />
        <TextBox x:Name="StudentSportsTeam" Text="SportsTeamHere" Margin="0.4" />
        
        <!--Actionable Buttons for each SP-->
        <Button x:Name="AddStudentBtn" Content="Add Student" Click="Add_Student" />
        <Button x:Name="UpdateStudentBtn" Content="Update Student" Click="Update_Student" />
        <Button x:Name="DeleteStudentBtn" Content="Delete Student" Click="Delete_Student" />
        <Button Content="Refresh Student DG" Click="Refresh_Click" />

    </StackPanel>
</Window>
